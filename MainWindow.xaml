<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GuitarTools.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Guitar Tools">

    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar: tuning selector -->
        <Grid Grid.Row="0" Background="#13131F" Padding="20,0">
            <ComboBox x:Name="TuningsComboBox"
                ItemsSource="{Binding Tunings}"
                SelectedItem="{Binding SelectedTuning, Mode=TwoWay}"
                DisplayMemberPath="Name"
                PlaceholderText="Select Tuning"
                FontSize="18"
                MaxWidth="420"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                SelectionChanged="Tuning_SelectionChanged"/>
        </Grid>

        <!-- Tuner Gauge (Win2D) with toggle button overlaid at pivot -->
        <Grid Grid.Row="1">
            <canvas:CanvasControl x:Name="TunerCanvas"
                                  Draw="TunerCanvas_Draw"
                                  Background="Transparent"/>
            <Button x:Name="TunerToggleButton"
                    Content="▶  Start"
                    Click="TunerToggle_Click"
                    Width="120"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,18"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <!-- Fretboard -->
        <Grid Grid.Row="2" Width="960" Height="380" Margin="20,10,20,20"
              x:Name="FretboardGrid" Background="#1A0F07">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Strings (horizontal) -->
            <Border Grid.Row="0" Grid.ColumnSpan="13" BorderBrush="#9B8B78" BorderThickness="0,0,0,1"/>
            <Border Grid.Row="1" Grid.ColumnSpan="13" BorderBrush="#B8A898" BorderThickness="0,0,0,1.5"/>
            <Border Grid.Row="2" Grid.ColumnSpan="13" BorderBrush="#B8A898" BorderThickness="0,0,0,1.75"/>
            <Border Grid.Row="3" Grid.ColumnSpan="13" BorderBrush="#B8A898" BorderThickness="0,0,0,2"/>
            <Border Grid.Row="4" Grid.ColumnSpan="13" BorderBrush="#B8A898" BorderThickness="0,0,0,2.25"/>
            <Border Grid.Row="5" Grid.ColumnSpan="13" BorderBrush="#B8A898" BorderThickness="0,0,0,2.5"/>

            <!-- Frets (vertical) — nut is bright, regular frets are silver -->
            <Border Grid.RowSpan="7" Grid.Column="0" BorderBrush="#E8E0D0" BorderThickness="0,0,8,0"/>
            <Border Grid.RowSpan="7" Grid.Column="1" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="2" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="3" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="4" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="5" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="6" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="7" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="8" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="9" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="10" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="11" BorderBrush="#707070" BorderThickness="1,0,3,0"/>
            <Border Grid.RowSpan="7" Grid.Column="12" BorderBrush="#707070" BorderThickness="1,0,3,0"/>

            <!-- Position dot markers -->
            <Ellipse Grid.Row="3" Grid.Column="3" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Grid.Row="3" Grid.Column="5" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Grid.Row="2" Grid.Column="7" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Grid.Row="4" Grid.Column="7" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Grid.Row="3" Grid.Column="9" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Grid.Row="2" Grid.Column="12" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Grid.Row="4" Grid.Column="12" Fill="#6A6050" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Fret numbers -->
            <TextBlock Grid.Row="7" Grid.Column="0" Text="0" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="1" Text="1" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="2" Text="2" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="3" Text="3" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="4" Text="4" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="5" Text="5" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="6" Text="6" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="7" Text="7" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="8" Text="8" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="9" Text="9" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="10" Text="10" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="11" Text="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="7" Grid.Column="12" Text="12" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
